# ==========================================
# Competitive Programming Contest Agent Config
# ==========================================

# Codeforces Configuration
CF_HANDLE=your_cf_handle

# Database Connection (Unified Client)
# Local SQLite Mode (Default):
DATABASE_URL=file:data/cf_agent.db
# Remote Turso / Serverless Mode (Uncomment to use Turso):
# DATABASE_URL=libsql://your-database-name.turso.io
# DATABASE_AUTH_TOKEN=your_turso_auth_token

# Google Tasks Configuration
# The ID of the task list to sync contests into.
# '@default' maps to your primary tasks list.
# You can also use a specific Task List ID or set it to automatically create a "Codeforces" list.
GOOGLE_TASKLIST_ID=@default

# Path to your Google OAuth client secrets file downloaded from Google Cloud Console.
# (Used locally by scripts/setup-oauth.ts and self-hosted mode)
GOOGLE_CREDENTIALS_PATH=data/credentials.json

# Path to the generated OAuth tokens file.
GOOGLE_TOKEN_PATH=data/token.json

# (Serverless-only) If running statelessly (e.g. Vercel) where files cannot be persisted,
# you can copy-paste the entire contents of token.json into this variable as a single string.
# GOOGLE_OAUTH_TOKEN_JSON='{"access_token": "...", "refresh_token": "...", ...}'

# Localization
TIMEZONE=Asia/Kolkata

# Cleanup & Archival Parameters
DELETE_UNATTEMPTED=true
MISSED_RETENTION_DAYS=3

# Web Server Configuration (Self-Hosted Daemon only)
PORT=3000
HOST=0.0.0.0

# Logging Level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Optional Telegram Notifications
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
# TELEGRAM_CHAT_ID=987654321

# Optional Discord Notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
